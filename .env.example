# Server
PORT=3001
NODE_ENV=development

# Database — leave DATABASE_URL empty to use local SQLite
DB_PATH=./tracker.db
DATABASE_URL=

# Auth — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Config file location (relative to backend/)
CONFIG_PATH=../config.json

# Google Calendar (optional — only needed for Google sync)
# Run `npm run auth` in backend/ to generate token.json
GOOGLE_CALENDAR_ID=

# Email alerts (optional — configure via /api/alerts/settings once SMTP is set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Salary Tracker <you@gmail.com>

# LemonSqueezy billing (Phase 3 — required to enable paid subscriptions)
# Get these from your LemonSqueezy dashboard → Settings → API / Store / Products
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID_MONTHLY=
LEMONSQUEEZY_VARIANT_ID_ANNUAL=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Public URL of the frontend (used for checkout redirect)
APP_URL=http://localhost:5173
